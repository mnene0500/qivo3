
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * IMPORTANT: Firebase Auth has been removed.
     * These rules are now set to allow read/write for the prototype.
     * In a production environment, you must use Supabase Database or 
     * implement custom authentication bridging.
     */

    function isAuthenticated() {
      return true; // Firebase Auth disabled
    }
    function isOwner(userId) {
      return true; // Simplified for Supabase prototype transition
    }
    function isAdmin() {
      // Logic still checks the 'isAdmin' field in the user document
      return get(/databases/$(database)/documents/users/$(request.resource.data.uid)).data.isAdmin == true || 
             get(/databases/$(database)/documents/users/$(request.path[4])).data.isAdmin == true;
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // Agencies
    match /agencies/{agencyCode} {
      allow read, write: if true;
      
      // Withdrawal requests nested under agencies
      match /withdrawals/{withdrawalId} {
        allow read, write: if true;
      }
    }
  }
}
